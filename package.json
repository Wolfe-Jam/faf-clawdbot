{
  "name": "faf-clawdbot",
  "version": "1.0.0",
  "description": "Portable souls for ClawdBot - IANA-registered context format integration",
  "main": "dist/index.js",
  "bin": {
    "faf-clawdbot": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "tsc && node dist/tests/wjttc.test.js",
    "test:wjttc": "node dist/tests/wjttc.test.js",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "clawdbot",
    "faf",
    "ai-context",
    "soul",
    "portable",
    "iana",
    "mcp"
  ],
  "author": "James Wolfe Harrison",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wolfe-Jam/faf-clawdbot"
  },
  "dependencies": {
    "yaml": "^2.3.4",
    "chokidar": "^3.5.3",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
